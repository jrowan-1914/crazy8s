generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String?   // Only for admin
  role          String    @default("player") // "admin" or "player"
  accessToken   String?   @unique // For player link-based access
  picksSubmitted Boolean  @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  picks         Pick[]
  sessions      Session[]
  accounts      Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Team {
  id         String       @id @default(cuid())
  name       String
  seed       Int          // 1-16
  region     String       // East, West, South, Midwest
  logoUrl    String?
  eliminated Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  picks      Pick[]
  wins       GameResult[] @relation("WinningTeam")
  losses     GameResult[] @relation("LosingTeam")

  @@unique([region, seed])
}

model Pick {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

model GameResult {
  id            String   @id @default(cuid())
  round         Int      // 1-6
  winningTeamId String
  losingTeamId  String
  gameDate      DateTime?
  createdAt     DateTime @default(now())
  winningTeam   Team     @relation("WinningTeam", fields: [winningTeamId], references: [id])
  losingTeam    Team     @relation("LosingTeam", fields: [losingTeamId], references: [id])

  @@unique([winningTeamId, losingTeamId, round])
}

model Settings {
  id             String   @id @default("global")
  picksLocked    Boolean  @default(false)
  tournamentName String   @default("College Basketball Tournament 2026")
  updatedAt      DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(cuid())
  author    String   // Player name (no auth required, just a name)
  message   String
  createdAt DateTime @default(now())
}
